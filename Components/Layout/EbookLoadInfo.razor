@using System.Threading
@using BookHeaven.Server.Features.Files.Abstractions
@using BookHeaven.Server.Features.Files.DTOs
@using BookHeaven.Server.Features.Files.Enums
@implements IDisposable
@if (Total == 0)
{
	return;
}

<MudCard Elevation="3" Class="animate-slide-in-bottom animate-duration-100">
	<MudCardContent>
		<div class="flex items-center justify-between">
			<span>Importing books...</span>
			@if (Processed == Total)
			{
				<MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Medium"></MudIcon>
			}
			else
			{
				<MudProgressCircular Indeterminate="true" Size="Size.Small" Color="Color.Primary"></MudProgressCircular>
			}
		</div>
		<div class="flex items-center justify-between mt-2">
			<span>@Processed/@Total</span>
			@if (Failed > 0)
			{
				<span class="text-red-400">@Failed failed</span>
			}
		</div>
	</MudCardContent>
</MudCard>

@code {
	[Inject] private IEbookLoadNotifier EbookLoadNotifier { get; set; } = null!;

	private readonly List<EbookLoadNotificationDto> _notifications = [];
	private int Total => _notifications.GroupBy(n => n.ItemId).Count();
	private int Success => _notifications.Where(n => n.Status == EbookLoadStatus.Success).GroupBy(n => n.ItemId).Count();
	private int Failed => _notifications.Where(n => n.Status == EbookLoadStatus.Failed).GroupBy(n => n.ItemId).Count();
	private int Processed => Success + Failed;
	
	// Cancellation token source used to cancel a pending clear delay.
	// We keep it nullable and recreate it every time a new delay is started.
	private CancellationTokenSource? _clearCts;

	protected override void OnInitialized()
	{
		EbookLoadNotifier.OnNotificationPublished += OnNotification;
	}

	private async void OnNotification(EbookLoadNotificationDto notification)
	{
		// Cancel and dispose any previous clear delay so the notifications remain visible when new items arrive.
		try
		{
			if(_clearCts is not null) await _clearCts.CancelAsync();
		}
		catch { 
			//Ignore
		}
		_clearCts?.Dispose();
		_clearCts = new CancellationTokenSource();
		var token = _clearCts.Token;

		_notifications.Add(notification);
		await InvokeAsync(StateHasChanged);

		if (Processed == Total)
		{
			// Start a delayed clear using the captured token. If another notification comes in, that token will be cancelled.
			_ = DelayedClearAsync(token);
		}
	}

	private async Task DelayedClearAsync(CancellationToken token)
	{
		try
		{
			await Task.Delay(TimeSpan.FromSeconds(5), token);
		}
		catch (OperationCanceledException)
		{
			// The delay was cancelled because a new notification arrived - do nothing.
			return;
		}

		_notifications.Clear();
		await InvokeAsync(StateHasChanged);
	}

	// Clean up event subscription and any pending CTS when the component is disposed.
	public void Dispose()
	{
		EbookLoadNotifier.OnNotificationPublished -= OnNotification;
		try
		{
			_clearCts?.Cancel();
		}
		catch
		{
			// ignore
		}
		_clearCts?.Dispose();
	}
}