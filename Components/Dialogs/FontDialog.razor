@using BookHeaven.Domain
@using BookHeaven.Domain.Abstractions
@using BookHeaven.Domain.Features.Fonts
<MudDialog>
	<DialogContent>
		<MudTextField Class="mb-5" Label="Font Name" HelperText="It can be whatever you want" Variant="Variant.Filled" @bind-Value="_fontFamily"/>

		<MudFileUpload
			T="IReadOnlyList<IBrowserFile>"
			@bind-Files="_files"
			AppendMultipleFiles
			Hidden="false"
			InputClass="absolute inset-0 opacity-0 overflow-hidden"
			OnFilesChanged="OnFilesChanged"
			SelectedTemplate="files => builder => { }"
			Accept=".ttf, .otf, .woff, .woff2"
			@ondrop="() => _dropZoneActive = false"
			@ondragenter="() => _dropZoneActive = true"
			@ondragleave="() => _dropZoneActive = false"
			@ondragend="() => _dropZoneActive = false">
			<CustomContent Context="fileUpload">
				<MudPaper Height="@DropZoneHeight" Class="@DropZoneClass" Outlined="true" @onclick="fileUpload.OpenFilePickerAsync">
					<MudStack Class="select-none">
						<MudText Color="Color.Secondary">Drop font files here</MudText>
						<MudText Color="Color.Secondary">- OR -</MudText>
						<MudText Color="Color.Secondary">Click to open file picker</MudText>
					</MudStack>
				</MudPaper>
			</CustomContent>
		</MudFileUpload>
		@if (_variants.Count > 0)
		{
			<MudText Typo="Typo.h6" Class="mt-5">Variants</MudText>
			<div class="grid grid-cols-[2fr_120px_120px_50px] items-center justify-center p-2 gap-5">
				@foreach (var variant in _variants.OrderByDescending(v => v.Style).ThenByDescending(v => v.Weight))
				{
					<MudText>@variant.FileName</MudText>
					<MudSelect Label="Style" @bind-Value="variant.Style" Variant="Variant.Filled" Margin="Margin.Dense">
						@foreach (var style in _styles)
						{
							<MudSelectItem Value="@style">@style</MudSelectItem>
						}
					</MudSelect>
					<MudSelect Label="Weight" @bind-Value="variant.Weight" Variant="Variant.Filled" Margin="Margin.Dense">
						@foreach (var weight in _weights)
						{
							<MudSelectItem Value="@weight">@weight</MudSelectItem>
						}
					</MudSelect>
					<div class="mx-auto">
						<MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" @onclick="() => _variants.Remove(variant)"/>
					</div>

				}
			</div>
		}
		@if (_variants.Count > 0)
		{
			<MudPaper Class="mt-3" Outlined="true">
				<style>
					@foreach (var variant in _variants)
					{
						@variant.GetFontFace();
					}

					#font-@_variants.First().Family p {
						font-family: '@_variants.First().Family';
						font-size: 16px;
						margin-bottom: 10px;
					}
				</style>
				<MudExpansionPanels Outlined="false" Elevation="0">
					<MudExpansionPanel Class="bg-neutral-300 text-black" Text="Preview">
						<div id="font-@_variants.First().Family" class="font-normal not-italic">
							<span class="text-neutral-700 uppercase">Regular</span>
							<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Morbi at. </p>
							<span class="text-neutral-700 uppercase">Bold</span>
							<p class="font-bold">Lorem ipsum dolor sit amet, consectetur adipiscing elit. Morbi at.</p>
							<span class="text-neutral-700 uppercase">Italic</span>
							<p class="italic">Lorem ipsum dolor sit amet, consectetur adipiscing elit. Morbi at.</p>
							<span class="text-neutral-700 uppercase">Bold Italic</span>
							<p class="font-bold italic">Lorem ipsum dolor sit amet, consectetur adipiscing elit. Morbi at.</p>
							<span class="text-neutral-700 uppercase">Sample</span>
							<p class="text-justify text-pretty italic m-6 mt-2">A wonderful serenity has taken possession of my entire soul, like these sweet mornings of spring which I enjoy with my whole heart.</p>
							<p class="text-justify text-pretty indent-4">I am alone, and feel the charm of existence in this spot, which was created for the bliss of souls like mine. I am so happy, my dear friend, so absorbed in the exquisite sense of mere tranquil existence, that I neglect my talents. I should be incapable of drawing a single stroke at the present moment.</p>
						</div>
					</MudExpansionPanel>
				</MudExpansionPanels>
			</MudPaper>
		}
	</DialogContent>
	<DialogActions>
		@if (!string.IsNullOrEmpty(Family))
		{
			<MudButton Class="me-auto" OnClick="async () => await DeleteFont()" Color="Color.Error">Delete</MudButton>
		}
		<MudButton OnClick="() => MudDialog.Cancel()" Color="Color.Warning">Cancel</MudButton>
		<MudButton OnClick="async () => await Save()" Color="Color.Primary">Save</MudButton>
	</DialogActions>
</MudDialog>

@code {
	[Inject] IDialogService DialogService { get; set; } = null!;
	[Inject] IAlertService AlertService { get; set; } = null!;
	[Inject] ISender Sender { get; set; } = null!;
	
	[CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
	[Parameter] public string? Family { get; set; }
	
	public static DialogOptions Options = new() { FullWidth = true };
	
	private readonly List<Font> _variants = [];
	private IReadOnlyList<IBrowserFile> _files = [];
	
	private readonly List<string> _styles = ["all", "normal", "italic"];
	private readonly List<string> _weights = ["all", "normal", "bold"];
	
	private string _fontFamily = string.Empty;

	private bool _dropZoneActive;
	private string DropZoneClass => $"flex items-center justify-center text-center p-5 rounded-xl border-2 border-dashed transition-[height] {(_dropZoneActive ? "mud-border-primary" : "")}";
	private string DropZoneHeight => _variants.Count > 0 ? "150px" : "300px";

	protected override async Task OnInitializedAsync()
	{
		if (!string.IsNullOrEmpty(Family))
		{
			var getVariants = await Sender.Send(new GetAllFonts.Query(Family));
			if (getVariants.IsSuccess)
			{
				_variants.AddRange(getVariants.Value);
			}
			_fontFamily = Family;
		}
	}

	private void OnFilesChanged(InputFileChangeEventArgs e)
	{
		var files = e.GetMultipleFiles();
		foreach (var file in files)
		{
			if (string.IsNullOrEmpty(_fontFamily))
			{
				if (files.Count == 1)
				{
					_fontFamily = file.Name;
				}
				else if(file.Name.Contains("-"))
				{
					_fontFamily = file.Name.Split("-")[0].Trim();
				}
			}
			var variant = new Font();
			if (files.Count == 1)
			{
				variant.Style = "all";
				variant.Weight = "all";
			}
			else
			{
				variant.Style = file.Name.ToLower().Contains("italic") ? "italic" : "normal";
				variant.Weight = file.Name.ToLower().Contains("bold") ? "bold" : "normal";
			}
			variant.FileName = file.Name;
			_variants.Add(variant);
		}
	}

	private async Task DeleteFont()
	{
		var result = await AlertService.ShowConfirmationAsync("Warning", "Do you really want to delete this font?", accept: "Yes", cancel: "No");
		if (result == true)
		{
			var deleteFont = await Sender.Send(new DeleteFont.Command(Family!));
			if (deleteFont.IsFailure)
			{
				await AlertService.ShowToastAsync(deleteFont.Error.Description, AlertSeverity.Error);
				return;
			}
			var folder = Path.Combine(DomainGlobals.FontsPath, Family!);
			if (Directory.Exists(folder))
			{
				Directory.Delete(folder, true);
			}
			MudDialog.Close();
		}
	}

	private async Task Save()
	{
		if (!string.IsNullOrEmpty(Family))
		{
			await AlertService.ShowToastAsync("Font editing not implemented yet");
			return;
		}
		if (string.IsNullOrEmpty(_fontFamily))
		{
			await AlertService.ShowToastAsync("Font family name is required", AlertSeverity.Error);
			return;
		}
		
		if (_variants.Count == 0)
		{
			await AlertService.ShowToastAsync("At least one font file is required", AlertSeverity.Error);
			return;
		}

		foreach (var variant in _variants)
		{
			variant.Family = _fontFamily;
			var addFont = await Sender.Send(new AddFont.Command(variant));
			if (addFont.IsFailure)
			{
				await AlertService.ShowToastAsync(addFont.Error.Description, AlertSeverity.Error);
				return;
			}

			var file = _files.First(f => f.Name == variant.FileName);
			var filePath = variant.FilePath();
			var folderPath = Path.GetDirectoryName(filePath);

			if (!Directory.Exists(folderPath))
			{
				Directory.CreateDirectory(folderPath!);
			}

			await using var fileStream = File.Create(filePath);
			await file.OpenReadStream(maxAllowedSize: 1048576 * 3).CopyToAsync(fileStream);
		}

		MudDialog.Close(_variants);
	}
	
	
}